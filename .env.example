# Runtime safety
DRY_RUN=true
POLL_INTERVAL_MINUTES=15
# When market/event fetch fails, continuous mode retries after this many seconds.
OFFLINE_RETRY_SECONDS=60
# In live mode, block trading on startup until open orders and positions are reconciled.
RECONCILE_ON_STARTUP=true
MAX_POSITION_USD=2.50
ENABLE_NO_SIDE=true
# Optional validation/debug cap. Leave unset or 0 for production.
LIVE_MARKET_LIMIT=0

# Streaming market data. REST remains the source of truth for market discovery,
# weather forecasts, startup reconciliation, periodic safety reconciliation,
# and reconnect recovery.
POLYMARKET_MARKET_WS_ENABLED=true
POLYMARKET_USER_WS_ENABLED=true
POLYMARKET_WS_BASE_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLYMARKET_WS_MARKET_STALE_SECONDS=20
POLYMARKET_WS_MARKET_MAX_TOKENS=200
POLYMARKET_WS_MARKET_WARMUP_SECONDS=1.5
POLYMARKET_WS_HEARTBEAT_SECONDS=10
POLYMARKET_WS_RECONNECT_MIN_SECONDS=5
POLYMARKET_WS_RECONNECT_MAX_SECONDS=60

# Live-mode REST safety reconciliation. Set interval to 0 only if another
# supervisor performs equivalent open-order/position reconciliation.
SAFETY_RECONCILE_INTERVAL_MINUTES=60
SAFETY_RECONCILE_MIN_INTERVAL_SECONDS=300

# Append-only event and touched-market snapshot logging.
EVENT_SNAPSHOT_INTERVAL_MINUTES=5

# Dashboard and live preflight wallet balance fallback. The dashboard still
# shows the CLOB balance/allowance response, but uses the funder wallet's
# Polygon collateral balance as the top-line account balance when the CLOB
# cache reports 0. Live order preflight can also use read-only wallet balance
# and on-chain allowance when CLOB reports exactly 0 during migration windows.
POLYMARKET_WALLET_BALANCE_TTL_SECONDS=60
POLYMARKET_WALLET_BALANCE_PREFLIGHT_FALLBACK=true
# Optional private RPC endpoint. Public fallbacks are used when unset.
POLYGON_RPC_URL=
POLYGON_RPC_FALLBACK_URLS=

# Optional override. The live bot defaults to production CLOB because Gamma
# active markets are production markets. Use clob-v2 only for explicit SDK
# test-host validation.
# POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Required only when DRY_RUN=false
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
# When API key auth returns 401, derive fresh CLOB API credentials from the
# private key and persist the repaired key/secret/passphrase to this .env file.
POLYMARKET_AUTH_WRITE_DOTENV=true

# Optional wallet settings used by py-clob-client-v2 for proxy wallets.
# Valid signature types: 0=EOA, 1=POLY_PROXY/Magic, 2=GNOSIS_SAFE.
# The private-key signer must derive/control the configured funder wallet; otherwise
# live orders will be rejected with "invalid signature" even if balance and allowance are funded.
POLYMARKET_SIGNATURE_TYPE=
POLYMARKET_FUNDER_ADDRESS=
# Optional V2 builder attribution. This replaces the old POLY_BUILDER_*
# HMAC order-signing headers; use the bytes32 builder code from your
# Polymarket Builder Profile if applicable.
POLY_BUILDER_CODE=
# Optional explicit address for Data API position reconciliation.
# Set this to the proxy/funder wallet that holds positions if it differs from the private-key address.
POLYMARKET_RECONCILE_USER_ADDRESS=
