# Output locations
COND_ARB_DATA_DIR=data
COND_ARB_LOG_DIR=logs

# Paper portfolio sizing and costs.
COND_ARB_STARTING_CAPITAL_USD=1000
COND_ARB_TRADE_CEILING_USD=100
COND_ARB_SLIPPAGE_BUFFER_BPS=10
COND_ARB_TAKER_FEE_BPS=0
COND_ARB_TAX_BPS=0
COND_ARB_MERGE_COST_USD=0.02
COND_ARB_MIN_NET_PROFIT_USD=0
COND_ARB_MIN_NET_RETURN_BPS=0
COND_ARB_MAX_BOOK_AGE_SECONDS=20

# Market data cadence and optional local validation cap.
COND_ARB_MARKET_LIMIT=0
COND_ARB_POLL_INTERVAL_SECONDS=60
COND_ARB_MARKET_WS_ENABLED=true
COND_ARB_MARKET_WS_ENDPOINT=wss://ws-subscriptions-clob.polymarket.com/ws/market
COND_ARB_MARKET_WS_HEARTBEAT_SECONDS=10
COND_ARB_MARKET_WS_MAX_ASSETS_PER_CONNECTION=500
COND_ARB_MARKET_REFRESH_INTERVAL_SECONDS=300
COND_ARB_REST_RECONCILE_INTERVAL_SECONDS=60
COND_ARB_WS_STALE_SECONDS=5
COND_ARB_UNIVERSE_CACHE_MAX_AGE_SECONDS=3600

# Optional CLOB host override. Gamma active markets are production markets.
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Paper execution realism controls.
COND_ARB_PAPER_SIMULATION_ENABLED=true
COND_ARB_PAPER_SIM_SEED=0
COND_ARB_PAPER_LATENCY_MS=250
COND_ARB_PAPER_LATENCY_JITTER_MS=50
COND_ARB_PAPER_LATENCY_MODE=fixed
COND_ARB_PAPER_LOCAL_TIMEOUT_MS=0
COND_ARB_PAPER_TELEMETRY_LATENCY_WINDOW=50
COND_ARB_PAPER_LATENCY_JITTER_SEED_SCOPE=market_book_stage
COND_ARB_PAPER_SIGNING_LATENCY_MS=50
COND_ARB_PAPER_SETTLEMENT_LATENCY_MS=1500
COND_ARB_PAPER_MAX_FILL_PRICE_MOVE_BPS=25
COND_ARB_PAPER_FILL_ELIGIBILITY_MODE=strict_public_depth
COND_ARB_PAPER_ALLOW_TRADE_PRINT_FILL_SUPPORT=true
COND_ARB_PAPER_ALLOW_DETERMINISTIC_FILL_FALLBACK=false
COND_ARB_PAPER_SETTLEMENT_ENABLED=true
COND_ARB_PAPER_SETTLEMENT_SOURCE=public_metadata_or_ws
COND_ARB_PAPER_UNMATCHED_OPEN_VALUATION=best_bid_midpoint_or_zero
COND_ARB_PAPER_SETTLEMENT_REQUIRE_WINNER=true
COND_ARB_PAPER_SLIPPAGE_MODE=fixed_plus_calibrated
COND_ARB_PAPER_SLIPPAGE_MAX_BPS=100
COND_ARB_PAPER_SLIPPAGE_LOOKBACK_EVENTS=50
COND_ARB_PAPER_SLIPPAGE_COMBINE_MODE=max
COND_ARB_PAPER_QUEUE_DEPTH_RATIO=0.75
COND_ARB_PAPER_QUEUE_FILL_PROBABILITY=0.95
COND_ARB_PAPER_PARTIAL_FILL_PROBABILITY=0.15
COND_ARB_PAPER_PARTIAL_FILL_MIN_RATIO=0.5
COND_ARB_PAPER_SUBMIT_FAILURE_PROBABILITY=0.005
COND_ARB_PAPER_ACCEPT_FAILURE_PROBABILITY=0.0025
COND_ARB_PAPER_FILL_FAILURE_PROBABILITY=0.01
COND_ARB_PAPER_CANCEL_FAILURE_PROBABILITY=0.0025
COND_ARB_PAPER_THROTTLE_MAX_SUBMISSIONS_PER_SECOND=8
COND_ARB_PAPER_THROTTLE_QUANTITY_RATIO=0.5
COND_ARB_PAPER_ADVERSE_SELECTION_PROBABILITY=0.25
COND_ARB_PAPER_ADVERSE_DEPTH_REMOVAL_RATIO=0.5
COND_ARB_PAPER_ADVERSE_PRICE_MOVE_BPS=10
