# Output locations
COND_ARB_DATA_DIR=data
COND_ARB_LOG_DIR=logs

# Scan cadence and optional local validation cap.
COND_ARB_MARKET_LIMIT=0
COND_ARB_POLL_INTERVAL_SECONDS=60

# Paper opportunity thresholds.
COND_ARB_MIN_NET_PROFIT_USD=0.25
COND_ARB_MIN_NET_RETURN_BPS=25
COND_ARB_MAX_CAPITAL_USD=50
COND_ARB_SLIPPAGE_BUFFER_BPS=10
COND_ARB_GAS_COST_USD=0.02
COND_ARB_TAKER_FEE_BPS=0
COND_ARB_MAX_BOOK_AGE_SECONDS=20
COND_ARB_INCLUDE_NEG_RISK=true

# Optional CLOB host override. Gamma active markets are production markets.
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
